{
  "name": "Aura Intake — Email + Sheets + Files",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "aura-intake",
        "responseMode": "responseNode",
        "options": {
          "allowedOrigins": "*"
        }
      },
      "id": "webhook-trigger",
      "name": "Webhook — Aura Intake",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "aura-intake"
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "{\"status\":\"received\"}",
        "options": {
          "responseHeaders": {
            "entries": [
              { "name": "Access-Control-Allow-Origin", "value": "*" },
              { "name": "Content-Type", "value": "application/json" }
            ]
          }
        }
      },
      "id": "respond-immediately",
      "name": "Respond Immediately",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [460, 180]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "1", "name": "leadName",        "value": "={{ $json.body.name || $json.body.returningEmail || 'Returning Client' }}", "type": "string" },
            { "id": "2", "name": "leadEmail",       "value": "={{ $json.body.email || $json.body.returningEmail }}", "type": "string" },
            { "id": "3", "name": "leadIndustry",    "value": "={{ $json.body.industry || 'N/A' }}", "type": "string" },
            { "id": "4", "name": "leadBottleneck",  "value": "={{ $json.body.bottleneck || 'N/A' }}", "type": "string" },
            { "id": "5", "name": "leadRequirements","value": "={{ $json.body.requirements || 'N/A' }}", "type": "string" },
            { "id": "6", "name": "isReturning",     "value": "={{ $json.body.returning === 'true' || $json.body.returning === true }}", "type": "boolean" },
            { "id": "7", "name": "entryPage",       "value": "={{ $json.body.entryPage || '/' }}", "type": "string" },
            { "id": "8", "name": "referrer",        "value": "={{ $json.body.referrer || 'Direct' }}", "type": "string" },
            { "id": "9", "name": "submittedAt",     "value": "={{ new Date($json.body.timestamp || Date.now()).toLocaleString('en-MY', { timeZone: 'Asia/Kuala_Lumpur', dateStyle: 'medium', timeStyle: 'short' }) }}", "type": "string" },
            { "id": "10","name": "waLink",          "value": "={{ 'https://wa.me/60104290595?text=Hi+' + encodeURIComponent($json.body.name || 'there') + ',+I+have+reviewed+your+Aura+brief+and+would+love+to+connect.' }}", "type": "string" },
            { "id": "11","name": "hasFiles",        "value": "={{ Array.isArray($json.body.files) && $json.body.files.length > 0 }}", "type": "boolean" },
            { "id": "12","name": "fileCount",       "value": "={{ Array.isArray($json.body.files) ? $json.body.files.length : 0 }}", "type": "number" }
          ]
        }
      },
      "id": "set-fields",
      "name": "Set — Format Fields",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [460, 300]
    },
    {
