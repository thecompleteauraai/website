%'><tr><td align='center'><a href='https://wa.me/60104290595' style='display:inline-block;background:linear-gradient(135deg,#25D366,#128C7E);color:#fff;font-family:Arial,sans-serif;font-weight:700;font-size:13px;text-decoration:none;padding:13px 28px;border-radius:9px;'>💬 Chat on WhatsApp</a></td></tr></table></td></tr><tr><td style='background:#040410;border:1px solid rgba(139,92,246,0.2);border-top:none;border-radius:0 0 16px 16px;padding:14px 32px;text-align:center;'><div style='font-size:11px;color:rgba(238,240,255,0.22);'>© 2025 The Complete Aura &nbsp;·&nbsp; India &amp; Malaysia</div></td></tr></table></body></html>"
      },
