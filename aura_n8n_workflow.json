        "sheetName": { "__rl": true, "value": "Leads", "mode": "name" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Timestamp":     "={{ $json.submittedAt }}",
            "Name":          "={{ $json.leadName }}",
            "Email":         "={{ $json.leadEmail }}",
            "Industry":      "={{ $json.leadIndustry }}",
            "Bottleneck":    "={{ $json.leadBottleneck }}",
            "Requirements":  "={{ $json.leadRequirements }}",
            "Returning":     "={{ $json.isReturning ? 'Yes' : 'No' }}",
            "Entry Page":    "={{ $json.entryPage }}",
            "Referrer":      "={{ $json.referrer }}",
            "Files":         "={{ $json.fileCount + ' file(s)' }}"
          }
        },
        "options": {}
      },
